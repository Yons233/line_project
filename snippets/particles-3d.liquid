{% comment %}
  particles-3d.liquid
  Sistema de partículas Three.js reutilizable.

  Parámetros (todos opcionales):
    particle_count  {number}  Cantidad de partículas. Default: 120
    particle_color  {string}  Color hex. Default: '#e7d3b3' (champagne-2)
    particle_size   {number}  Tamaño base. Default: 1.2
    section_id      {string}  ID único de la sección (evita colisiones de IDs)

  Uso:
    {% render 'particles-3d',
       particle_count: 150,
       particle_color: '#bd9763',
       particle_size: 1.5,
       section_id: section.id %}
{% endcomment %}

{% assign p_count = particle_count | default: 120 %}
{% assign p_color = particle_color | default: '#e7d3b3' %}
{% assign p_size  = particle_size  | default: 1.2 %}
{% assign p_id    = section_id     | default: 'particles' %}

<div
  class="line-particles"
  data-particles-canvas="canvas-{{ p_id }}"
  data-count="{{ p_count }}"
  data-color="{{ p_color }}"
  data-size="{{ p_size }}"
  aria-hidden="true"
>
  <canvas
    id="canvas-{{ p_id }}"
    class="line-particles__canvas"
  ></canvas>

  {%- comment -%} Fallback estático: gradiente CSS visible en móvil / reduced-motion {%- endcomment -%}
  <div class="line-particles__fallback"></div>
</div>

<style>
  .line-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }
  .line-particles__canvas {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .line-particles__canvas.is-ready {
    opacity: 1;
  }
  .line-particles__fallback {
    display: none;
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 40%, rgba(189,151,99,0.12) 0%, transparent 70%);
  }
  .line-anim--fallback .line-particles__canvas { display: none; }
  .line-anim--fallback .line-particles__fallback { display: block; }

  @media (prefers-reduced-motion: reduce) {
    .line-particles__canvas { display: none; }
    .line-particles__fallback { display: block; }
  }
</style>

<script>
(function () {
  var container = document.querySelector('[data-particles-canvas="canvas-{{ p_id }}"]');
  if (!container) return;

  var isMobile = window.matchMedia('(max-width: 768px)').matches;
  var isReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (isMobile || isReduced) {
    container.classList.add('line-anim--fallback');
    return;
  }

  function initParticles(el) {
    if (!window.THREE) return;

    var THREE = window.THREE;
    var canvas = document.getElementById('canvas-{{ p_id }}');
    if (!canvas) return;

    var count  = parseInt(el.dataset.count, 10)  || {{ p_count }};
    var color  = el.dataset.color                 || '{{ p_color }}';
    var size   = parseFloat(el.dataset.size)      || {{ p_size }};

    var renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    var scene  = new THREE.Scene();
    var camera = new THREE.PerspectiveCamera(60, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
    camera.position.z = 5;

    var geometry = new THREE.BufferGeometry();
    var positions = new Float32Array(count * 3);
    var velocities = new Float32Array(count * 3);

    for (var i = 0; i < count; i++) {
      positions[i * 3]     = (Math.random() - 0.5) * 12;
      positions[i * 3 + 1] = (Math.random() - 0.5) * 8;
      positions[i * 3 + 2] = (Math.random() - 0.5) * 6;
      velocities[i * 3]     = (Math.random() - 0.5) * 0.002;
      velocities[i * 3 + 1] = (Math.random() - 0.5) * 0.002;
      velocities[i * 3 + 2] = 0;
    }

    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));

    var material = new THREE.PointsMaterial({
      color: new THREE.Color(color),
      size: size * 0.05,
      sizeAttenuation: true,
      transparent: true,
      opacity: 0.65,
    });

    var points = new THREE.Points(geometry, material);
    scene.add(points);

    var rafId = null;
    var isVisible = true;

    function resize() {
      var w = canvas.clientWidth;
      var h = canvas.clientHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    function animate() {
      if (!isVisible) return;
      rafId = requestAnimationFrame(animate);

      var pos = geometry.attributes.position.array;
      for (var j = 0; j < count; j++) {
        pos[j * 3]     += velocities[j * 3];
        pos[j * 3 + 1] += velocities[j * 3 + 1];
        // Wrap around
        if (pos[j * 3] >  6) pos[j * 3] = -6;
        if (pos[j * 3] < -6) pos[j * 3] =  6;
        if (pos[j * 3 + 1] >  4) pos[j * 3 + 1] = -4;
        if (pos[j * 3 + 1] < -4) pos[j * 3 + 1] =  4;
      }
      geometry.attributes.position.needsUpdate = true;

      points.rotation.y += 0.0003;
      renderer.render(scene, camera);
    }

    // Pausar cuando la sección sale del viewport
    var visObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          isVisible = true;
          animate();
        } else {
          isVisible = false;
          if (rafId) cancelAnimationFrame(rafId);
        }
      });
    });
    visObserver.observe(el);

    canvas.classList.add('is-ready');
    animate();
  }

  if (window.LINE && window.LINE.registerAnim) {
    window.LINE.registerAnim(container, initParticles, ['three'], '200px');
  } else {
    // fallback si line-anim.js no cargó aún
    document.addEventListener('DOMContentLoaded', function () {
      if (window.LINE && window.LINE.registerAnim) {
        window.LINE.registerAnim(container, initParticles, ['three'], '200px');
      }
    });
  }
})();
</script>
