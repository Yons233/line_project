{% comment %}
  particles-3d.liquid — Canvas Three.js reutilizable con lazy load autónomo.

  Parámetros:
    particle_count  {number}  Default: 120
    particle_color  {string}  Default: '#e7d3b3'
    particle_size   {number}  Default: 1.2
    section_id      {string}  ID único para evitar colisiones de canvas
{% endcomment %}

{% assign p_count = particle_count | default: 120 %}
{% assign p_color = particle_color | default: '#e7d3b3' %}
{% assign p_size  = particle_size  | default: 1.2 %}
{% assign p_id    = section_id     | default: 'particles' %}

<div
  class="line-particles"
  id="line-particles-{{ p_id }}"
  data-count="{{ p_count }}"
  data-color="{{ p_color }}"
  data-size="{{ p_size }}"
  aria-hidden="true"
>
  <canvas id="canvas-{{ p_id }}" class="line-particles__canvas"></canvas>
  <div class="line-particles__fallback"></div>
</div>

<style>
  .line-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }
  .line-particles__canvas {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
    transition: opacity 1s ease;
  }
  .line-particles__canvas.is-ready { opacity: 1; }
  .line-particles__fallback {
    display: none;
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 65% 35%, rgba(189,151,99,0.14) 0%, transparent 65%);
  }
  .line-particles--fallback .line-particles__canvas { display: none; }
  .line-particles--fallback .line-particles__fallback { display: block; }
  @media (prefers-reduced-motion: reduce) {
    .line-particles__canvas { display: none; }
    .line-particles__fallback { display: block; }
  }
</style>

<script>
(function () {
  var wrap   = document.getElementById('line-particles-{{ p_id }}');
  var canvas = document.getElementById('canvas-{{ p_id }}');
  if (!wrap || !canvas) return;

  /* Salir en móvil o reduced-motion */
  if (window.matchMedia('(max-width: 768px)').matches ||
      window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    wrap.classList.add('line-particles--fallback');
    return;
  }

  var threeUrl = {{ 'three.min.js' | asset_url | json }};
  var loaded   = false;
  var rafId    = null;
  var isVisible = false;

  /* Carga Three.js una sola vez aunque haya varios snippets en página */
  function loadThree(cb) {
    if (window.THREE) { cb(); return; }
    window.__lineThreeCallbacks = window.__lineThreeCallbacks || [];
    window.__lineThreeCallbacks.push(cb);
    if (window.__lineThreeLoading) return;
    window.__lineThreeLoading = true;
    var s = document.createElement('script');
    s.src = threeUrl;
    s.defer = true;
    s.onload = function () {
      (window.__lineThreeCallbacks || []).forEach(function (fn) { fn(); });
      window.__lineThreeCallbacks = [];
    };
    document.head.appendChild(s);
  }

  /* IntersectionObserver 1: activar lazy load al entrar en viewport */
  new IntersectionObserver(function (entries, obs) {
    if (!entries[0].isIntersecting) return;
    obs.disconnect();
    loadThree(initScene);
  }, { rootMargin: '200px' }).observe(wrap);

  /* IntersectionObserver 2: pausar rAF fuera del viewport */
  var visObserver = new IntersectionObserver(function (entries) {
    isVisible = entries[0].isIntersecting;
    if (isVisible && loaded) tick();
    else if (!isVisible && rafId) { cancelAnimationFrame(rafId); rafId = null; }
  });

  /* Textura circular suave (mota de luz) generada por canvas, sin assets externos */
  function makeDotTexture() {
    var size = 64;
    var c = document.createElement('canvas');
    c.width = c.height = size;
    var ctx = c.getContext('2d');
    var r = size / 2;
    var grad = ctx.createRadialGradient(r, r, 0, r, r, r);
    grad.addColorStop(0,    'rgba(255,255,255,1)');
    grad.addColorStop(0.4,  'rgba(255,255,255,0.6)');
    grad.addColorStop(1,    'rgba(255,255,255,0)');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, size, size);
    var tex = new window.THREE.CanvasTexture(c);
    tex.needsUpdate = true;
    return tex;
  }

  function initScene() {
    if (loaded) return;
    loaded = true;

    var THREE  = window.THREE;
    var count  = parseInt(wrap.dataset.count, 10) || {{ p_count }};
    var color  = wrap.dataset.color               || '{{ p_color }}';
    var size   = parseFloat(wrap.dataset.size)    || {{ p_size }};

    var renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    var scene  = new THREE.Scene();
    var camera = new THREE.PerspectiveCamera(60, (canvas.clientWidth || 1) / (canvas.clientHeight || 1), 0.1, 1000);
    camera.position.z = 5;

    var positions  = new Float32Array(count * 3);
    var velocities = new Float32Array(count * 3);
    for (var i = 0; i < count; i++) {
      positions[i*3]     = (Math.random() - 0.5) * 12;
      positions[i*3 + 1] = (Math.random() - 0.5) * 8;
      positions[i*3 + 2] = (Math.random() - 0.5) * 6;
      velocities[i*3]     = (Math.random() - 0.5) * 0.0018;
      velocities[i*3 + 1] = (Math.random() - 0.5) * 0.0018;
    }

    var geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    var mat = new THREE.PointsMaterial({
      color: new THREE.Color(color),
      map: makeDotTexture(),
      size: size * 0.05,
      sizeAttenuation: true,
      transparent: true,
      depthWrite: false,
      opacity: 0.7
    });
    var points = new THREE.Points(geo, mat);
    scene.add(points);

    function resize() {
      var w = canvas.clientWidth, h = canvas.clientHeight;
      if (!w || !h) return;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    function tick() {
      if (!isVisible) return;
      rafId = requestAnimationFrame(tick);
      var pos = geo.attributes.position.array;
      for (var j = 0; j < count; j++) {
        pos[j*3]     += velocities[j*3];
        pos[j*3 + 1] += velocities[j*3 + 1];
        if (pos[j*3]     >  6) pos[j*3]     = -6;
        if (pos[j*3]     < -6) pos[j*3]     =  6;
        if (pos[j*3 + 1] >  4) pos[j*3 + 1] = -4;
        if (pos[j*3 + 1] < -4) pos[j*3 + 1] =  4;
      }
      geo.attributes.position.needsUpdate = true;
      points.rotation.y += 0.0003;
      renderer.render(scene, camera);
    }

    canvas.classList.add('is-ready');
    isVisible = true;
    visObserver.observe(wrap);
    tick();
  }
})();
</script>
