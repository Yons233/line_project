{% comment %}
  icon-category.liquid — Iconos SVG inline para "Explora nuestras categorías" (Explore-our-category-home) y para el submenú de "Categorías" en el header.
  Representan las mismas 9 categorías que aparecen en las esferas del video del Hero.
  Diseños basados en librerías de iconos de línea reconocidas (Lucide/Feather/Tabler),
  con grosor de trazo y proporciones unificadas para que se vean como un set premium coherente.

  Parámetros:
    icon {string} — uno de: facial, fitness-ligero, postura, skincare, relajacion,
                     sueno, anti-estres, dolor-muscular, belleza
{% endcomment %}

{%- case icon -%}

  {%- when 'facial' -%}
    <svg viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
      <path d="M12 2.8c-3.8 0-6.5 3.4-6.5 8 0 4.2 2.5 8.6 6.5 9.4 4-.8 6.5-5.2 6.5-9.4 0-4.6-2.7-8-6.5-8z"/>
    </svg>

  {%- when 'fitness-ligero' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12.5 5.5c1.4-1.5 2.6-2 4-2A5 5 0 0 1 21 8.5c0 2.1-1.4 3.7-2.8 5.1L12 20l-6.2-6.4C4.4 12.2 3 10.6 3 8.5A5 5 0 0 1 8 3.5c1.4 0 2.6.5 4.5 2z"/>
      <path d="M2.5 11h4l1.5-3 2 5 1.5-2.5H21" stroke-linejoin="round"/>
    </svg>

  {%- when 'postura' -%}
    <svg viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
      <circle cx="12" cy="4.5" r="1.4"/>
      <circle cx="12" cy="9.5" r="1.4"/>
      <circle cx="12" cy="14.5" r="1.4"/>
      <circle cx="12" cy="19.5" r="1.4"/>
    </svg>

  {%- when 'skincare' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
    </svg>

  {%- when 'relajacion' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M2 9c1.3 1 1.3 1 2.5 1 2.5 0 2.5-2 5-2 2.5 0 2.5 2 5 2 2.6 0 2.4-2 5-2 1.2 0 1.2 0 2.5 1"/>
      <path d="M2 15c1.3 1 1.3 1 2.5 1 2.5 0 2.5-2 5-2 2.5 0 2.5 2 5 2 2.6 0 2.4-2 5-2 1.2 0 1.2 0 2.5 1"/>
    </svg>

  {%- when 'sueno' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>

  {%- when 'anti-estres' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <ellipse cx="12" cy="19" rx="6.5" ry="2.4"/>
      <ellipse cx="12" cy="13" rx="4.6" ry="2"/>
      <ellipse cx="12" cy="7.5" rx="2.8" ry="1.6"/>
    </svg>

  {%- when 'dolor-muscular' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9"/>
      <circle cx="12" cy="12" r="5.5"/>
      <circle cx="12" cy="12" r="2"/>
    </svg>

  {%- when 'belleza' -%}
    <svg viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
      <path d="M12 2.5l2.9 5.88 6.5.94-4.7 4.58 1.11 6.47L12 17.27l-5.81 3.1 1.11-6.47-4.7-4.58 6.5-.94L12 2.5z"/>
    </svg>

  {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="8"/>
    </svg>

{%- endcase -%}
