{% stylesheet %}
.line-footer {
  background: var(--ink);
  color: var(--cream-1);
  padding-top: var(--space-20);
  padding-bottom: var(--space-8);
}

.line-footer__top {
  display: grid;
  grid-template-columns: 1.4fr repeat(3, 1fr);
  gap: var(--space-12);
  padding-bottom: var(--space-16);
  border-bottom: 1px solid rgba(247,242,234,0.10);
}

/* Columna brand */
.line-footer__brand-logo {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-4);
}
.line-footer__brand-logo img { height: 32px; width: auto; }
.line-footer__brand-logo-text {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: var(--text-xl);
  color: var(--cream-0);
  letter-spacing: -0.02em;
}
.line-footer__brand-desc {
  font-size: var(--text-sm);
  color: var(--ink-soft);
  line-height: 1.7;
  max-width: 280px;
  color: rgba(247,242,234,0.55);
}
.line-footer__social {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-6);
}
.line-footer__social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: var(--radius-full);
  border: 1px solid rgba(247,242,234,0.15);
  color: var(--cream-1);
  transition: border-color var(--duration-fast), background var(--duration-fast);
}
.line-footer__social-link:hover {
  border-color: var(--champagne-1);
  background: rgba(189,151,99,0.12);
}

/* Columnas de links */
.line-footer__col-title {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  color: var(--champagne-2);
  margin-bottom: var(--space-4);
}
.line-footer__col-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.line-footer__col-link {
  font-size: var(--text-sm);
  color: rgba(247,242,234,0.65);
  transition: color var(--duration-fast);
}
.line-footer__col-link:hover { color: var(--cream-0); }

/* Parte inferior */
.line-footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-4);
  padding-top: var(--space-8);
}
.line-footer__copy {
  font-size: var(--text-xs);
  color: rgba(247,242,234,0.40);
}
.line-footer__legal {
  display: flex;
  gap: var(--space-6);
}
.line-footer__legal-link {
  font-size: var(--text-xs);
  color: rgba(247,242,234,0.45);
  transition: color var(--duration-fast);
}
.line-footer__legal-link:hover { color: var(--cream-1); }

@media (max-width: 900px) {
  .line-footer__top {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-10);
  }
  .line-footer__brand { grid-column: 1 / -1; }
}
@media (max-width: 480px) {
  .line-footer__top { grid-template-columns: 1fr; }
  .line-footer__bottom { flex-direction: column; text-align: center; }
  .line-footer__legal { justify-content: center; }
}
{% endstylesheet %}

<footer class="line-footer" role="contentinfo">
  <div class="container">
    <div class="line-footer__top">

      <!-- Brand -->
      <div class="line-footer__brand">
        <div class="line-footer__brand-logo">
          {%- if section.settings.logo != blank -%}
            {{
              section.settings.logo
              | image_url: width: 160
              | image_tag:
                loading: 'lazy',
                alt: shop.name,
                widths: '80,160'
            }}
          {%- else -%}
            <span class="line-footer__brand-logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </div>
        {%- if section.settings.description != blank -%}
          <p class="line-footer__brand-desc">{{ section.settings.description }}</p>
        {%- endif -%}
        <div class="line-footer__social" aria-label="{{ 'sections.footer.social_media' | t }}">
          {%- if section.settings.social_instagram != blank -%}
            <a href="{{ section.settings.social_instagram }}" class="line-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_facebook != blank -%}
            <a href="{{ section.settings.social_facebook }}" class="line-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_tiktok != blank -%}
            <a href="{{ section.settings.social_tiktok }}" class="line-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.29 6.29 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.53V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Columnas de links dinámicas (blocks) -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <p class="line-footer__col-title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="line-footer__col-links" role="list">
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}" class="line-footer__col-link">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    <!-- Parte inferior -->
    <div class="line-footer__bottom">
      <p class="line-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.footer.all_rights' | t }}
      </p>
      <nav class="line-footer__legal" aria-label="{{ 'sections.footer.legal_nav' | t }}">
        {%- for link in section.settings.legal_menu.links -%}
          <a href="{{ link.url }}" class="line-footer__legal-link">{{ link.title }}</a>
        {%- endfor -%}
      </nav>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo en footer"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Productos de bienestar pensados para tu día a día. Calidad, comodidad y estilo.",
      "label": "Descripción de la marca"
    },
    {
      "type": "header",
      "content": "Redes sociales"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok"
    },
    {
      "type": "header",
      "content": "Menú legal"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Menú de políticas (Términos, Privacidad, etc.)"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Columna de links",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Compra",
          "label": "Título de la columna"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menú"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_column", "settings": { "title": "Productos" } },
        { "type": "link_column", "settings": { "title": "Ayuda" } },
        { "type": "link_column", "settings": { "title": "Empresa" } }
      ]
    }
  ]
}
{% endschema %}
