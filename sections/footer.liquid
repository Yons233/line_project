{% stylesheet %}
.line-footer {
  background: var(--cream-0);
  color: var(--ink);
  padding-top: var(--space-20);
  padding-bottom: var(--space-5);
}

.line-footer__inner {
  max-width: 1760px;
  margin-inline: auto;
  padding-inline: var(--container-pad);
}

.line-footer__top {
  display: grid;
  grid-template-columns: 1.3fr repeat(4, 0.8fr) 1.15fr;
  gap: var(--space-10);
  padding-bottom: var(--space-16);
  border-bottom: 1px solid rgba(42,36,30,0.10);
}

/* Columna brand */
.line-footer__brand-logo {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-4);
}
.line-footer__brand-logo img { height: 34px; width: auto; }
.line-footer__brand-logo-text {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: var(--text-xl);
  color: var(--ink);
  letter-spacing: -0.02em;
}
.line-footer__brand-desc {
  font-size: var(--text-sm);
  line-height: 1.7;
  max-width: 280px;
  color: rgba(42,36,30,0.6);
}
.line-footer__social {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-top: var(--space-6);
}
.line-footer__social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink);
  transition: color var(--duration-fast), transform var(--duration-fast);
}
.line-footer__social-link svg { width: 18px; height: 18px; }
.line-footer__social-link:hover {
  color: var(--champagne-1);
  transform: translateY(-2px);
}

/* Columnas de links */
.line-footer__col-title {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  color: var(--champagne-1);
  margin-bottom: var(--space-4);
}
.line-footer__col-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.line-footer__col-link {
  font-size: var(--text-sm);
  color: rgba(42,36,30,0.65);
  transition: color var(--duration-fast);
}
.line-footer__col-link:hover { color: var(--ink); }

/* Bloque de pago seguro */
.line-footer__trust {
  padding-left: var(--space-10);
  border-left: 1px solid rgba(42,36,30,0.10);
}
.line-footer__trust-badge {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}
.line-footer__trust-icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: rgba(42,36,30,0.04);
  border: 1px solid rgba(42,36,30,0.12);
  color: var(--champagne-1);
}
.line-footer__trust-icon svg { width: 32px; height: 32px; }
.line-footer__trust-text {
  display: flex;
  flex-direction: column;
}
.line-footer__trust-title {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--ink);
}
.line-footer__trust-desc {
  margin-top: 2px;
  font-size: var(--text-xs);
  color: rgba(42,36,30,0.55);
}

.line-footer__pay {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-6);
}
.line-footer__pay-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64px;
  height: 36px;
  padding-inline: 0;
  border-radius: 6px;
  background: var(--white);
  border: 1px solid rgba(42,36,30,0.08);
  box-shadow: 0 1px 2px rgba(42,36,30,0.04);
  transition: box-shadow var(--duration-fast), transform var(--duration-fast);
}
.line-footer__pay-badge:hover {
  box-shadow: 0 4px 10px rgba(42,36,30,0.08);
  transform: translateY(-1px);
}
.line-footer__pay-badge img {
  height: 16px;
  width: auto;
  display: block;
}
.line-footer__pay-badge--paypal img { height: 28px; }
.line-footer__pay-badge--applepay img { height: 24px; }
.line-footer__pay-badge--gpay img { height: 24px; }
.line-footer__pay-badge--mastercard { position: relative; }
.line-footer__pay-mc-circle {
  width: 18px;
  height: 18px;
  border-radius: 50%;
}
.line-footer__pay-mc-circle--red { background: #eb001b; margin-right: -5px; }
.line-footer__pay-mc-circle--yellow { background: #f79e1b; mix-blend-mode: multiply; }

/* Parte inferior — copyright centrado, links legales (si existen) debajo */
.line-footer__bottom {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  padding-top: var(--space-3);
  text-align: center;
}
.line-footer__copy {
  font-size: var(--text-xs);
  color: rgba(42,36,30,0.78);
}
.line-footer__legal {
  display: flex;
  justify-content: center;
  gap: var(--space-6);
}
.line-footer__legal-link {
  font-size: var(--text-xs);
  color: rgba(42,36,30,0.55);
  transition: color var(--duration-fast);
}
.line-footer__legal-link:hover { color: var(--ink); }

@media (max-width: 1100px) {
  .line-footer__top {
    grid-template-columns: repeat(3, 1fr);
    row-gap: var(--space-12);
  }
  .line-footer__brand { grid-column: 1 / -1; }
  .line-footer__trust {
    grid-column: 1 / -1;
    padding-left: 0;
    border-left: none;
    padding-top: var(--space-8);
    border-top: 1px solid rgba(42,36,30,0.10);
  }
}
@media (max-width: 700px) {
  .line-footer__top { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .line-footer__top { grid-template-columns: 1fr; }
  .line-footer__bottom { flex-direction: column; text-align: center; }
  .line-footer__legal { justify-content: center; }
}
{% endstylesheet %}

<footer class="line-footer" role="contentinfo">
  <div class="line-footer__inner">
    <div class="line-footer__top">

      <!-- Brand -->
      <div class="line-footer__brand">
        <div class="line-footer__brand-logo">
          {%- if section.settings.logo != blank -%}
            {{
              section.settings.logo
              | image_url: width: 160
              | image_tag:
                loading: 'lazy',
                alt: shop.name,
                widths: '80,160'
            }}
          {%- elsif section.settings.logo_fallback != blank -%}
            <img
              src="{{ section.settings.logo_fallback | asset_url }}"
              alt="{{ shop.name }}"
              loading="lazy"
              width="170"
              height="34"
            >
          {%- else -%}
            <span class="line-footer__brand-logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </div>
        {%- if section.settings.description != blank -%}
          <p class="line-footer__brand-desc">{{ section.settings.description }}</p>
        {%- endif -%}
        <div class="line-footer__social" aria-label="{{ 'sections.footer.social_media' | t }}">
          <a href="{{ section.settings.social_instagram | default: '#' }}" class="line-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/>
            </svg>
          </a>
          <a href="{{ section.settings.social_tiktok | default: '#' }}" class="line-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.29 6.29 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.53V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
            </svg>
          </a>
          <a href="{{ section.settings.social_facebook | default: '#' }}" class="line-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Columnas de links dinámicas (blocks) -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="line-footer__linkcol" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <p class="line-footer__col-title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.menu != blank and block.settings.menu.links.size > 0 -%}
              <ul class="line-footer__col-links" role="list">
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}" class="line-footer__col-link">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <!-- Enlaces de respaldo: se muestran solo mientras no se asigne un menú real desde el editor -->
              <ul class="line-footer__col-links" role="list">
                {%- case block.settings.title -%}
                  {%- when 'Ver y comprar' -%}
                    <li><a href="{{ routes.collections_url }}" class="line-footer__col-link">Categorías</a></li>
                    <li><a href="#" class="line-footer__col-link">Envíos</a></li>
                    <li><a href="#" class="line-footer__col-link">Devoluciones</a></li>
                    <li><a href="#" class="line-footer__col-link">Rastrear mi pedido</a></li>
                  {%- when 'Empresa' -%}
                    <li><a href="/pages/por-que-line" class="line-footer__col-link">¿Por qué LINE?</a></li>
                    <li><a href="/pages/acerca-de" class="line-footer__col-link">Sobre Nosotros</a></li>
                    <li><a href="#" class="line-footer__col-link">Tu experiencia en LINE</a></li>
                  {%- when 'Legal' -%}
                    <li><a href="#" class="line-footer__col-link">Aviso legal</a></li>
                    <li><a href="{{ shop.policies.privacy_policy.url | default: '#' }}" class="line-footer__col-link">Privacidad</a></li>
                    <li><a href="{{ shop.policies.refund_policy.url | default: '#' }}" class="line-footer__col-link">Políticas</a></li>
                    <li><a href="{{ shop.policies.terms_of_service.url | default: '#' }}" class="line-footer__col-link">Condiciones de servicio</a></li>
                  {%- when 'Ayuda' -%}
                    <li><a href="/pages/contacto" class="line-footer__col-link">Contáctanos</a></li>
                    <li><a href="/pages/faq" class="line-footer__col-link">Preguntas frecuentes</a></li>
                    <li><a href="{{ shop.policies.refund_policy.url | default: '#' }}" class="line-footer__col-link">Devoluciones/Reembolso</a></li>
                {%- endcase -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      <!-- Pago seguro -->
      <div class="line-footer__trust">
        <div class="line-footer__trust-badge">
          <span class="line-footer__trust-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </span>
          <span class="line-footer__trust-text">
            <span class="line-footer__trust-title">{{ 'sections.footer.secure_checkout' | t }}</span>
            <span class="line-footer__trust-desc">{{ 'sections.footer.secure_checkout_desc' | t }}</span>
          </span>
        </div>
        <div class="line-footer__pay" aria-hidden="true">
          <span class="line-footer__pay-badge line-footer__pay-badge--visa">
            <img src="{{ 'VisaL.png' | asset_url }}" alt="Visa" loading="lazy" width="623" height="368">
          </span>
          <span class="line-footer__pay-badge line-footer__pay-badge--mastercard">
            <span class="line-footer__pay-mc-circle line-footer__pay-mc-circle--red"></span>
            <span class="line-footer__pay-mc-circle line-footer__pay-mc-circle--yellow"></span>
          </span>
          <span class="line-footer__pay-badge line-footer__pay-badge--paypal">
            <img src="{{ 'Paypal.png' | asset_url }}" alt="PayPal" loading="lazy" width="500" height="500">
          </span>
          <span class="line-footer__pay-badge line-footer__pay-badge--applepay">
            <img src="{{ 'ApplePay.png' | asset_url }}" alt="Apple Pay" loading="lazy" width="612" height="408">
          </span>
          <span class="line-footer__pay-badge line-footer__pay-badge--gpay">
            <img src="{{ 'GooglePay.png' | asset_url }}" alt="Google Pay" loading="lazy" width="577" height="433">
          </span>
        </div>
      </div>

    </div>

    <!-- Parte inferior -->
    <div class="line-footer__bottom">
      <p class="line-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.footer.all_rights' | t }}
      </p>
      <nav class="line-footer__legal" aria-label="{{ 'sections.footer.legal_nav' | t }}">
        {%- for link in section.settings.legal_menu.links -%}
          <a href="{{ link.url }}" class="line-footer__legal-link">{{ link.title }}</a>
        {%- endfor -%}
      </nav>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo en footer"
    },
    {
      "type": "text",
      "id": "logo_fallback",
      "default": "Logo.png",
      "label": "Logo de respaldo (archivo en assets/, se usa si no hay logo arriba)"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Soluciones de bienestar innovadoras, diseñadas para mejorar tu día a día.",
      "label": "Descripción de la marca"
    },
    {
      "type": "header",
      "content": "Redes sociales"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook"
    },
    {
      "type": "header",
      "content": "Menú legal"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Menú de políticas (Términos, Privacidad, etc.)"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Columna de links",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Empresa",
          "label": "Título de la columna"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menú"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_column", "settings": { "title": "Empresa" } },
        { "type": "link_column", "settings": { "title": "Atención al cliente" } },
        { "type": "link_column", "settings": { "title": "Información" } },
        { "type": "link_column", "settings": { "title": "Soporte" } }
      ]
    }
  ]
}
{% endschema %}
