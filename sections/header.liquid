{% stylesheet %}
.line-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  height: var(--header-h);
  background: transparent;
  transition:
    background var(--duration-base) var(--ease-in-out),
    backdrop-filter var(--duration-base) var(--ease-in-out),
    box-shadow var(--duration-base) var(--ease-in-out);
}
.line-header.is-scrolled {
  background: var(--pastel-nav);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 1px 0 rgba(42,36,30,0.08), 0 2px 8px rgba(42,36,30,0.06);
}
.line-header--solid {
  background: var(--pastel-nav);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 1px 0 rgba(42,36,30,0.08);
}
.line-header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-pad);
  gap: var(--space-8);
}

/* ── Logo ── */
.line-header__logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  text-decoration: none;
}
.line-header__logo-img {
  height: 36px;
  width: auto;
}
.line-header__logo-text {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: var(--text-xl);
  color: var(--ink);
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

/* ── Nav ── */
.line-header__nav {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  list-style: none;
  flex: 1;
  justify-content: center;
}
.line-header__nav-link {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--ink);
  position: relative;
  padding-block: var(--space-1);
  white-space: nowrap;
  transition: color var(--duration-fast);
}
.line-header__nav-link::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 0;
  height: 1.5px;
  background: var(--champagne-1);
  transition: width var(--duration-base) var(--ease-out-expo);
}
.line-header__nav-link:hover::after,
.line-header__nav-link[aria-current="page"]::after { width: 100%; }

/* ── Acciones ── */
.line-header__actions {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex-shrink: 0;
}
.line-header__icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-full);
  color: var(--ink);
  position: relative;
  transition: background var(--duration-fast);
}
.line-header__icon-btn:hover { background: var(--cream-2); }
.line-header__cart-count {
  position: absolute;
  top: 4px;
  right: 4px;
  min-width: 16px;
  height: 16px;
  padding-inline: 3px;
  background: var(--champagne-1);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
.line-header__cart-count[hidden] { display: none; }

/* ── Mobile toggle ── */
.line-header__menu-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  width: 40px;
  height: 40px;
  padding: 10px;
  cursor: pointer;
  background: none;
  border: none;
  border-radius: var(--radius-full);
  transition: background var(--duration-fast);
}
.line-header__menu-toggle:hover { background: var(--cream-2); }
.line-header__menu-toggle span {
  display: block;
  height: 1.5px;
  background: var(--ink);
  border-radius: 2px;
  transition: transform var(--duration-base) var(--ease-out-expo),
              opacity var(--duration-fast);
}
.line-header__menu-toggle[aria-expanded="true"] span:nth-child(1) {
  transform: translateY(6.5px) rotate(45deg);
}
.line-header__menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.line-header__menu-toggle[aria-expanded="true"] span:nth-child(3) {
  transform: translateY(-6.5px) rotate(-45deg);
}

/* ── Mobile drawer ── */
.line-header__mobile-nav {
  display: none;
  position: fixed;
  inset: var(--header-h) 0 0 0;
  background: var(--cream-0);
  padding: var(--space-8) var(--container-pad);
  flex-direction: column;
  gap: var(--space-2);
  overflow-y: auto;
  z-index: 999;
}
.line-header__mobile-nav.is-open { display: flex; }
.line-header__mobile-nav-link {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--ink);
  padding-block: var(--space-4);
  border-bottom: 1px solid var(--cream-2);
  text-decoration: none;
  display: block;
}
.line-header__mobile-nav-link:last-child { border-bottom: none; }

@media (max-width: 900px) {
  .line-header__nav { display: none; }
  .line-header__menu-toggle { display: flex; }
}
{% endstylesheet %}

{%- assign has_hero = false -%}
{%- if template.name == 'index' -%}{%- assign has_hero = true -%}{%- endif -%}

<header
  class="line-header{% unless has_hero %} line-header--solid{% endunless %}"
  id="line-header"
  role="banner"
>
  <div class="line-header__inner">

    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="line-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: 240
          | image_tag:
            class: 'line-header__logo-img',
            alt: shop.name,
            loading: 'eager',
            widths: '120,160,240'
        }}
      {%- else -%}
        <span class="line-header__logo-text">{{ section.settings.logo_text | default: 'LINE' }}</span>
      {%- endif -%}
    </a>

    <!-- Navegación principal (desde blocks) -->
    <nav aria-label="{{ 'accessibility.main_nav' | t }}">
      <ul class="line-header__nav" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_link' -%}
            <li {{ block.shopify_attributes }}>
              <a
                href="{{ block.settings.url | default: '#' }}"
                class="line-header__nav-link"
                {% if block.settings.url == request.path %}aria-current="page"{% endif %}
              >{{ block.settings.label }}</a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </nav>

    <!-- Acciones -->
    <div class="line-header__actions">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}" class="line-header__icon-btn" aria-label="{{ 'general.search.search' | t }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="line-header__icon-btn" aria-label="{{ 'cart.general.title' | t }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="line-header__cart-count" {% if cart.item_count == 0 %}hidden{% endif %}>
          {{ cart.item_count }}
        </span>
      </a>

      <button
        class="line-header__menu-toggle"
        aria-label="{{ 'sections.header.menu' | t }}"
        aria-expanded="false"
        aria-controls="line-mobile-nav"
      ><span></span><span></span><span></span></button>
    </div>

  </div>
</header>

<!-- Menú móvil -->
<nav id="line-mobile-nav" class="line-header__mobile-nav" aria-label="{{ 'accessibility.mobile_nav' | t }}" hidden>
  {%- for block in section.blocks -%}
    {%- if block.type == 'nav_link' -%}
      <a
        href="{{ block.settings.url | default: '#' }}"
        class="line-header__mobile-nav-link"
        {% if block.settings.url == request.path %}aria-current="page"{% endif %}
      >{{ block.settings.label }}</a>
    {%- endif -%}
  {%- endfor -%}
</nav>

<div style="height:var(--header-h);" aria-hidden="true"
  class="line-header-spacer{% if has_hero %} visually-hidden{% endif %}"></div>

{% javascript %}
(function () {
  var header  = document.getElementById('line-header');
  var toggle  = document.querySelector('.line-header__menu-toggle');
  var mobileNav = document.getElementById('line-mobile-nav');
  if (!header) return;

  if (!header.classList.contains('line-header--solid')) {
    var ticking = false;
    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(function () {
          header.classList.toggle('is-scrolled', window.scrollY > 40);
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  if (toggle && mobileNav) {
    toggle.addEventListener('click', function () {
      var open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      if (open) {
        mobileNav.setAttribute('hidden', '');
        mobileNav.classList.remove('is-open');
        document.body.style.overflow = '';
      } else {
        mobileNav.removeAttribute('hidden');
        mobileNav.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
    });
    mobileNav.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        toggle.setAttribute('aria-expanded', 'false');
        mobileNav.setAttribute('hidden', '');
        mobileNav.classList.remove('is-open');
        document.body.style.overflow = '';
      });
    });
  }
})();
{% endjavascript %}

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (imagen)"
    },
    {
      "type": "text",
      "id": "logo_text",
      "default": "LINE",
      "label": "Logo (texto, si no hay imagen)"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "default": true,
      "label": "Mostrar icono de búsqueda"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Enlace de navegación",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "default": "Categorías",
          "label": "Texto del enlace"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header LINE",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "Categorías",        "url": "/collections" } },
        { "type": "nav_link", "settings": { "label": "¿Por qué LINE?",    "url": "/pages/por-que-line" } },
        { "type": "nav_link", "settings": { "label": "Acerca de Nosotros","url": "/pages/acerca-de" } },
        { "type": "nav_link", "settings": { "label": "FAQ",               "url": "/pages/faq" } },
        { "type": "nav_link", "settings": { "label": "Contáctanos",       "url": "/pages/contacto" } }
      ]
    }
  ]
}
{% endschema %}
