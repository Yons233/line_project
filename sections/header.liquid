{% stylesheet %}
.line-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  height: var(--header-h);
  background: rgba(var(--pastel-nav-rgb), 0);
  backdrop-filter: blur(0px);
  -webkit-backdrop-filter: blur(0px);
  box-shadow: 0 1px 0 rgba(42,36,30,0), 0 2px 8px rgba(42,36,30,0);
  transition:
    background 0.6s var(--ease-out-expo),
    backdrop-filter 0.6s var(--ease-out-expo),
    -webkit-backdrop-filter 0.6s var(--ease-out-expo),
    box-shadow 0.6s var(--ease-out-expo);
}
.line-header.is-scrolled {
  background: rgba(var(--pastel-nav-rgb), 1);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 1px 0 rgba(42,36,30,0.08), 0 2px 8px rgba(42,36,30,0.06);
}
.line-header--solid {
  background: rgba(var(--pastel-nav-rgb), 1);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 1px 0 rgba(42,36,30,0.08);
  transition: none;
}
.line-header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-pad);
  gap: var(--space-8);
}

/* ── Logo ── */
.line-header__logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  text-decoration: none;
  margin-left: -11.5rem;
}
.line-header__logo-img {
  height: 36px;
  width: auto;
}

/* ── Nav ── */
.line-header__nav {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  list-style: none;
  flex: 1;
  justify-content: center;
}
.line-header__nav-link {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--ink);
  position: relative;
  padding-block: var(--space-1);
  white-space: nowrap;
  transition: color var(--duration-fast);
}
.line-header__nav-link::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 0;
  height: 1.5px;
  background: var(--champagne-1);
  transition: width var(--duration-base) var(--ease-out-expo);
}
.line-header__nav-link:hover::after,
.line-header__nav-link[aria-current="page"]::after { width: 100%; }

/* ── Dropdown de categorías ── */
.line-header__nav-item { position: relative; }
.line-header__nav-caret {
  width: 9px;
  height: 9px;
  margin-left: 4px;
  vertical-align: middle;
  transition: transform var(--duration-base) var(--ease-out-expo);
}
.line-header__nav-item.has-dropdown:hover .line-header__nav-caret,
.line-header__nav-item.has-dropdown:focus-within .line-header__nav-caret {
  transform: rotate(180deg);
}
.line-header__dropdown {
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  padding-top: 18px; /* zona puente invisible: mantiene el hover activo entre el link y el panel */
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity var(--duration-base) var(--ease-out-expo),
              visibility var(--duration-base);
  z-index: 50;
}
.line-header__nav-item.has-dropdown:hover .line-header__dropdown,
.line-header__nav-item.has-dropdown:focus-within .line-header__dropdown {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
.line-header__dropdown-inner {
  position: relative;
  width: 460px;
  background: rgba(255,255,255,0.82);
  backdrop-filter: blur(28px) saturate(180%);
  -webkit-backdrop-filter: blur(28px) saturate(180%);
  backdrop-filter: blur(22px) saturate(190%) url(#line-liquid-glass);
  border-radius: 30px;
  border-top: 1px solid rgba(255,255,255,0.85);
  border-left: 1px solid rgba(255,255,255,0.6);
  border-right: 1px solid rgba(255,255,255,0.35);
  border-bottom: 1px solid rgba(255,255,255,0.25);
  box-shadow:
    0 1px 1px rgba(255,255,255,0.6) inset,
    0 -14px 20px rgba(42,36,30,0.05) inset,
    0 2px 6px rgba(42,36,30,0.05),
    0 16px 32px rgba(42,36,30,0.14),
    0 32px 56px rgba(42,36,30,0.12);
  padding: var(--space-4);
  transform: translateY(8px);
  transition: transform var(--duration-base) var(--ease-out-expo);
  overflow: hidden;
}
@supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
  .line-header__dropdown-inner { background: rgba(255,255,255,0.97); }
}
.line-header__nav-item.has-dropdown:hover .line-header__dropdown-inner,
.line-header__nav-item.has-dropdown:focus-within .line-header__dropdown-inner {
  transform: translateY(0);
}
.line-header__dropdown-inner::before {
  content: '';
  position: absolute;
  top: -30%;
  left: -10%;
  width: 65%;
  height: 65%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.75) 0%, rgba(255,255,255,0.25) 45%, rgba(255,255,255,0) 72%);
  pointer-events: none;
  mix-blend-mode: overlay;
}
.line-header__dropdown-inner::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(160deg, rgba(255,255,255,0.35) 0%, rgba(255,255,255,0) 30%, rgba(255,255,255,0) 75%, rgba(255,255,255,0.18) 100%);
  mix-blend-mode: overlay;
  pointer-events: none;
}
.line-header__dropdown-eyebrow,
.line-header__dropdown-list,
.line-header__dropdown-footer {
  position: relative;
  z-index: 1;
}
.line-header__dropdown-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--champagne-1);
  margin-bottom: var(--space-3);
}
.line-header__dropdown-eyebrow::before {
  content: '';
  width: 14px;
  height: 2px;
  background: var(--gradient-champagne);
  border-radius: var(--radius-full);
}
.line-header__dropdown-list {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(3, max-content);
  justify-content: space-between;
  gap: var(--space-1) var(--space-4);
}
.line-header__dropdown-link {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-1) var(--space-2);
  border-radius: 12px;
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
  white-space: nowrap;
  transition: background var(--duration-fast), color var(--duration-fast), transform var(--duration-fast);
}
.line-header__dropdown-link:hover {
  background: var(--cream-1);
  color: var(--champagne-1);
  transform: translateX(2px);
}
.line-header__dropdown-icon {
  position: relative;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: radial-gradient(circle at 32% 26%, #ffffff 0%, rgba(255,255,255,0.9) 45%, rgba(231,211,179,0.4) 85%);
  border: 1px solid rgba(255,255,255,0.85);
  box-shadow: 0 3px 8px rgba(42,36,30,0.10), inset -1px -2px 3px rgba(189,151,99,0.16);
  color: var(--champagne-1);
  transition: background var(--duration-fast), box-shadow var(--duration-fast), color var(--duration-fast);
}
.line-header__dropdown-icon svg { width: 13px; height: 13px; }
.line-header__dropdown-link:hover .line-header__dropdown-icon {
  background: linear-gradient(135deg, var(--champagne-2) 0%, var(--champagne-1) 100%);
  border-color: transparent;
  box-shadow: 0 4px 12px rgba(189,151,99,0.35);
  color: var(--white);
}
.line-header__dropdown-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: var(--space-3);
  padding-top: var(--space-3);
  border-top: 1px solid rgba(42,36,30,0.08);
}
.line-header__dropdown-viewall {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: 13px;
  font-weight: 600;
  color: var(--ink);
  transition: color var(--duration-fast);
}
.line-header__dropdown-viewall svg {
  width: 13px;
  height: 13px;
  transition: transform var(--duration-base) var(--ease-out-expo);
}
.line-header__dropdown-viewall:hover { color: var(--champagne-1); }
.line-header__dropdown-viewall:hover svg { transform: translateX(3px); }

/* ── Acciones ── */
.line-header__actions {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex-shrink: 0;
}
.line-header__icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-full);
  color: var(--ink);
  position: relative;
  transition: background var(--duration-fast);
}
.line-header__icon-btn:hover { background: var(--cream-2); }
.line-header__cart-count {
  position: absolute;
  top: 4px;
  right: 4px;
  min-width: 16px;
  height: 16px;
  padding-inline: 3px;
  background: var(--champagne-1);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* ── Mobile toggle ── */
.line-header__menu-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  width: 40px;
  height: 40px;
  padding: 10px;
  cursor: pointer;
  background: none;
  border: none;
  border-radius: var(--radius-full);
  transition: background var(--duration-fast);
}
.line-header__menu-toggle:hover { background: var(--cream-2); }
.line-header__menu-toggle span {
  display: block;
  height: 1.5px;
  background: var(--ink);
  border-radius: 2px;
  transition: transform var(--duration-base) var(--ease-out-expo),
              opacity var(--duration-fast);
}
.line-header__menu-toggle[aria-expanded="true"] span:nth-child(1) {
  transform: translateY(6.5px) rotate(45deg);
}
.line-header__menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.line-header__menu-toggle[aria-expanded="true"] span:nth-child(3) {
  transform: translateY(-6.5px) rotate(-45deg);
}

/* ── Mobile drawer ── */
.line-header__mobile-nav {
  display: none;
  position: fixed;
  inset: var(--header-h) 0 0 0;
  background: var(--cream-0);
  padding: var(--space-8) var(--container-pad);
  flex-direction: column;
  gap: var(--space-2);
  overflow-y: auto;
  z-index: 999;
}
.line-header__mobile-nav.is-open { display: flex; }
.line-header__mobile-nav-link {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--ink);
  padding-block: var(--space-4);
  border-bottom: 1px solid var(--cream-2);
  text-decoration: none;
  display: block;
}
.line-header__mobile-nav-link:last-child { border-bottom: none; }
.line-header__mobile-nav-item { border-bottom: 1px solid var(--cream-2); }
.line-header__mobile-nav-item:last-child { border-bottom: none; }
.line-header__mobile-nav-row { display: flex; align-items: center; justify-content: space-between; }
.line-header__mobile-nav-row .line-header__mobile-nav-link { border-bottom: none; flex: 1; }
.line-header__mobile-nav-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  flex-shrink: 0;
  background: none;
  border: none;
  color: var(--ink);
}
.line-header__mobile-nav-toggle svg {
  width: 16px;
  height: 16px;
  transition: transform var(--duration-base) var(--ease-out-expo);
}
.line-header__mobile-nav-toggle[aria-expanded="true"] svg { transform: rotate(180deg); }
.line-header__mobile-submenu {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows var(--duration-base) var(--ease-out-expo);
}
.line-header__mobile-nav-item.is-open .line-header__mobile-submenu { grid-template-rows: 1fr; }
.line-header__mobile-submenu-inner { overflow: hidden; }
.line-header__mobile-submenu-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  padding-bottom: var(--space-3);
}
.line-header__mobile-submenu-link {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding-block: var(--space-2);
  padding-left: var(--space-4);
  font-size: var(--text-sm);
  font-weight: 500;
  color: rgba(42,36,30,0.7);
}
.line-header__mobile-submenu-icon { display: flex; color: var(--champagne-1); }
.line-header__mobile-submenu-icon svg { width: 15px; height: 15px; }

@media (max-width: 900px) {
  .line-header__nav { display: none; }
  .line-header__menu-toggle { display: flex; }
  .line-header__logo { margin-left: 0; }
}
{% endstylesheet %}

{%- assign has_hero = false -%}
{%- if template.name == 'index' -%}{%- assign has_hero = true -%}{%- endif -%}

{%- comment -%} Categorías del menú desplegable: icono|etiqueta|handle-de-colección {%- endcomment -%}
{%- assign line_categories = 'facial|Facial|facial,fitness-ligero|Fitness ligero|fitness-ligero,postura|Postura|postura,skincare|Skincare|skincare,relajacion|Relajación|relajacion,sueno|Sueño|sueno,anti-estres|Anti estrés|anti-estres,dolor-muscular|Dolor muscular|dolor-muscular,belleza|Belleza|belleza' -%}
{%- assign line_categories_list = line_categories | split: ',' -%}

<svg width="0" height="0" style="position:absolute;overflow:hidden;" aria-hidden="true">
  <filter id="line-liquid-glass" x="-20%" y="-20%" width="140%" height="140%" filterUnits="objectBoundingBox">
    <feTurbulence type="fractalNoise" baseFrequency="0.009 0.012" numOctaves="2" seed="7" result="noise"/>
    <feGaussianBlur in="noise" stdDeviation="2" result="blurredNoise"/>
    <feDisplacementMap in="SourceGraphic" in2="blurredNoise" scale="26" xChannelSelector="R" yChannelSelector="G"/>
  </filter>
</svg>

<header
  class="line-header{% unless has_hero %} line-header--solid{% endunless %}"
  id="line-header"
  role="banner"
>
  <div class="line-header__inner">

    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="line-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: 240
          | image_tag:
            class: 'line-header__logo-img',
            alt: shop.name,
            loading: 'eager',
            widths: '120,160,240'
        }}
      {%- else -%}
        <img
          src="{{ 'Logo.png' | asset_url }}"
          alt="{{ shop.name }}"
          class="line-header__logo-img"
          loading="eager"
          width="320"
          height="64"
        >
      {%- endif -%}
    </a>

    <!-- Navegación principal (desde blocks) -->
    <nav aria-label="{{ 'accessibility.main_nav' | t }}">
      <ul class="line-header__nav" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_link' -%}
            <li class="line-header__nav-item{% if block.settings.has_dropdown %} has-dropdown{% endif %}" {{ block.shopify_attributes }}>
              <a
                href="{{ block.settings.url | default: '#' }}"
                class="line-header__nav-link"
                {% if block.settings.url == request.path %}aria-current="page"{% endif %}
                {% if block.settings.has_dropdown %}aria-haspopup="true" aria-expanded="false"{% endif %}
              >{{ block.settings.label }}{% if block.settings.has_dropdown %}
                <svg class="line-header__nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              {% endif %}</a>
              {%- if block.settings.has_dropdown -%}
                <div class="line-header__dropdown">
                  <div class="line-header__dropdown-inner">
                    <p class="line-header__dropdown-eyebrow">Explora por categoría</p>
                    <ul class="line-header__dropdown-list" role="list">
                      {%- for cat in line_categories_list -%}
                        {%- assign cat_parts = cat | split: '|' -%}
                        <li>
                          <a href="{{ routes.collections_url }}/{{ cat_parts[2] }}" class="line-header__dropdown-link">
                            <span class="line-header__dropdown-icon">{%- render 'icon-category', icon: cat_parts[0] -%}</span>
                            {{ cat_parts[1] }}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                    <div class="line-header__dropdown-footer">
                      <a href="{{ block.settings.url | default: routes.collections_url }}" class="line-header__dropdown-viewall">
                        Ver todas las categorías
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                      </a>
                    </div>
                  </div>
                </div>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </nav>

    <!-- Acciones -->
    <div class="line-header__actions">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}" class="line-header__icon-btn" aria-label="{{ 'general.search.search' | t }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="line-header__icon-btn" aria-label="{{ 'customer.account.title' | t }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="8" r="4"/>
          </svg>
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="line-header__icon-btn" aria-label="{{ 'cart.general.title' | t }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="line-header__cart-count">
          {{ cart.item_count }}
        </span>
      </a>

      <button
        class="line-header__menu-toggle"
        aria-label="{{ 'sections.header.menu' | t }}"
        aria-expanded="false"
        aria-controls="line-mobile-nav"
      ><span></span><span></span><span></span></button>
    </div>

  </div>
</header>

<!-- Menú móvil -->
<nav id="line-mobile-nav" class="line-header__mobile-nav" aria-label="{{ 'accessibility.mobile_nav' | t }}" hidden>
  {%- for block in section.blocks -%}
    {%- if block.type == 'nav_link' -%}
      {%- if block.settings.has_dropdown -%}
        <div class="line-header__mobile-nav-item">
          <div class="line-header__mobile-nav-row">
            <a
              href="{{ block.settings.url | default: '#' }}"
              class="line-header__mobile-nav-link"
              {% if block.settings.url == request.path %}aria-current="page"{% endif %}
            >{{ block.settings.label }}</a>
            <button type="button" class="line-header__mobile-nav-toggle" aria-expanded="false" aria-label="{{ block.settings.label }}">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </button>
          </div>
          <div class="line-header__mobile-submenu">
            <div class="line-header__mobile-submenu-inner">
              <ul class="line-header__mobile-submenu-list" role="list">
                {%- for cat in line_categories_list -%}
                  {%- assign cat_parts = cat | split: '|' -%}
                  <li>
                    <a href="{{ routes.collections_url }}/{{ cat_parts[2] }}" class="line-header__mobile-submenu-link">
                      <span class="line-header__mobile-submenu-icon">{%- render 'icon-category', icon: cat_parts[0] -%}</span>
                      {{ cat_parts[1] }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          </div>
        </div>
      {%- else -%}
        <a
          href="{{ block.settings.url | default: '#' }}"
          class="line-header__mobile-nav-link"
          {% if block.settings.url == request.path %}aria-current="page"{% endif %}
        >{{ block.settings.label }}</a>
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
</nav>

<div style="height:var(--header-h);" aria-hidden="true"
  class="line-header-spacer{% if has_hero %} visually-hidden{% endif %}"></div>

{% javascript %}
(function () {
  var header  = document.getElementById('line-header');
  var toggle  = document.querySelector('.line-header__menu-toggle');
  var mobileNav = document.getElementById('line-mobile-nav');
  if (!header) return;

  if (!header.classList.contains('line-header--solid')) {
    var ticking = false;
    var scrolled = false;
    /* Histéresis: umbrales distintos para activar/desactivar evita parpadeo cerca del borde */
    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(function () {
          if (!scrolled && window.scrollY > 48) {
            scrolled = true;
            header.classList.add('is-scrolled');
          } else if (scrolled && window.scrollY < 24) {
            scrolled = false;
            header.classList.remove('is-scrolled');
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  if (toggle && mobileNav) {
    toggle.addEventListener('click', function () {
      var open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      if (open) {
        mobileNav.setAttribute('hidden', '');
        mobileNav.classList.remove('is-open');
        document.body.style.overflow = '';
      } else {
        mobileNav.removeAttribute('hidden');
        mobileNav.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
    });
    mobileNav.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        toggle.setAttribute('aria-expanded', 'false');
        mobileNav.setAttribute('hidden', '');
        mobileNav.classList.remove('is-open');
        document.body.style.overflow = '';
      });
    });
    mobileNav.querySelectorAll('.line-header__mobile-nav-toggle').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = btn.closest('.line-header__mobile-nav-item');
        var open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        item.classList.toggle('is-open', !open);
      });
    });
  }
})();
{% endjavascript %}

