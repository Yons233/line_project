{% stylesheet %}
/* ── Hero container ── */
.line-hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  padding-top: calc(var(--header-h) + var(--space-16));
  padding-bottom: var(--space-16);
  background-color: var(--cream-0);
}

/* ── Fondo: video único (sin imagen ni animación de partículas) ── */
.line-hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
  background-color: var(--cream-0);
}
.line-hero__bg-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  opacity: 0;
  transition: opacity 1s ease;
  pointer-events: none;
}
.line-hero__bg-video.is-ready { opacity: 1; }
@media (max-width: 768px) {
  .line-hero__bg-video { display: none; }
}
@media (prefers-reduced-motion: reduce) {
  .line-hero__bg-video { display: none; }
}
.line-hero__bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(247,242,234,0.32) 0%,
    rgba(239,231,218,0.16) 45%,
    rgba(247,242,234,0.04) 100%
  );
}

/* ── Inner grid ── */
.line-hero__inner {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr;
  max-width: 1560px;
  margin-inline: auto;
  padding-inline: var(--container-pad);
  width: 100%;
}

/* ── Columna de texto ── */
.line-hero__content {
  display: grid;
  gap: var(--space-6);
  max-width: 640px;
}

.line-hero__label {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  background: rgba(255,255,255,0.55);
  border: 1px solid rgba(189,151,99,0.28);
  font-size: var(--text-sm);
  font-weight: 500;
  letter-spacing: normal;
  text-transform: none;
  color: var(--ink);
  width: fit-content;
}
.line-hero__label-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--champagne-1);
  flex-shrink: 0;
}

.line-hero__title {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: clamp(2.5rem, 5.5vw, 5.5rem);
  line-height: 1.0;
  letter-spacing: -0.03em;
  color: var(--ink);
}
.line-hero__title-line { display: block; }
.line-hero__title-line--gradient {
  background: var(--gradient-champagne);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.line-hero__subtitle {
  font-size: clamp(var(--text-base), 1.4vw, var(--text-lg));
  color: var(--ink-soft);
  line-height: 1.7;
  max-width: 480px;
}

.line-hero__cta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  align-items: center;
}
.line-hero__cta .btn { justify-content: space-between; }

/* ── Trust bar ── */
.line-hero__trust {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-6);
  align-items: center;
  padding-top: var(--space-4);
}
.line-hero__trust-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}
.line-hero__trust-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  background: rgba(255,255,255,0.55);
  border: 1px solid rgba(42,36,30,0.10);
  flex-shrink: 0;
}
.line-hero__trust-icon {
  width: 18px;
  height: 18px;
  color: var(--ink);
  flex-shrink: 0;
}
.line-hero__trust-text {
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.line-hero__trust-title {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--ink);
  line-height: 1.3;
}
.line-hero__trust-subtitle {
  font-size: var(--text-xs);
  color: var(--ink-soft);
  line-height: 1.3;
}

/* ── Responsive ── */
@media (max-width: 767px) {
  .line-hero {
    min-height: auto;
    padding-bottom: var(--space-20);
  }
}
@media (max-width: 600px) {
  .line-hero__title { letter-spacing: -0.02em; }
  .line-hero__trust { gap: var(--space-4); }
  .line-hero__cta { flex-direction: column; align-items: stretch; }
  .line-hero__cta .btn { width: 100%; }
}
{% endstylesheet %}

<section
  class="line-hero"
  id="line-hero-{{ section.id }}"
  aria-labelledby="hero-title-{{ section.id }}"
>

  <!-- Video de fondo (única capa visual; en móvil/reduced-motion queda solo el color base del hero) -->
  <div class="line-hero__bg" id="line-hero-bg-{{ section.id }}" aria-hidden="true">
    {%- if section.settings.show_bg_video -%}
      <video
        class="line-hero__bg-video"
        id="line-hero-bg-video-{{ section.id }}"
        muted
        loop
        playsinline
        autoplay
        preload="auto"
        disablepictureinpicture
        disableremoteplayback
        tabindex="-1"
        aria-hidden="true"
      ></video>
    {%- endif -%}

    <div class="line-hero__bg-overlay"></div>
  </div>

  {%- if section.settings.show_bg_video -%}
    <script>
    (function () {
      var wrap  = document.getElementById('line-hero-bg-{{ section.id }}');
      var video = document.getElementById('line-hero-bg-video-{{ section.id }}');
      if (!wrap || !video) return;

      /* Regla dura: desactivar en móvil y con prefers-reduced-motion (queda solo el color base del hero) */
      var skip = window.matchMedia('(max-width: 768px)').matches ||
                 window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (skip) return;

      /* Solo se revela (opacity) cuando ya hay un frame real avanzando:
         así nunca se ve un cuadro negro si el autoplay falla o tarda. */
      video.addEventListener('timeupdate', function onTick() {
        video.removeEventListener('timeupdate', onTick);
        video.classList.add('is-ready');
      });

      var source = document.createElement('source');
      source.src  = {{ 'OficialHero.mp4' | asset_url | json }};
      source.type = 'video/mp4';
      video.appendChild(source);
      video.load();
      video.play().catch(function () {
        /* Autoplay bloqueado por el navegador: queda solo el color base del hero */
      });

      /* Pausa fuera de viewport (scroll) para no gastar CPU/batería de más */
      new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) {
          video.play().catch(function () {});
        } else {
          video.pause();
        }
      }).observe(wrap);
    })();
    </script>
  {%- endif -%}

  <!-- Grid principal -->
  <div class="line-hero__inner">

    <!-- Columna de texto -->
    <div class="line-hero__content">

      {%- if section.settings.label != blank -%}
        <p class="line-hero__label">
          <span class="line-hero__label-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M12 5v14M5 12h14"/>
            </svg>
          </span>
          {{ section.settings.label }}
        </p>
      {%- endif -%}

      <h1 class="line-hero__title" id="hero-title-{{ section.id }}">
        {%- if section.settings.title_line_1 != blank -%}
          <span class="line-hero__title-line">{{ section.settings.title_line_1 }}</span>
        {%- endif -%}
        {%- if section.settings.title_line_2 != blank -%}
          <span class="line-hero__title-line">{{ section.settings.title_line_2 }}</span>
        {%- endif -%}
        {%- if section.settings.title_line_3 != blank -%}
          <span class="line-hero__title-line line-hero__title-line--gradient">{{ section.settings.title_line_3 }}</span>
        {%- endif -%}
      </h1>

      {%- if section.settings.subtitle != blank -%}
        <p class="line-hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <div class="line-hero__cta">
        {%- if section.settings.btn1_label != blank -%}
          <a href="{{ section.settings.btn1_url | default: '/collections/all' }}" class="btn btn--primary">
            {{ section.settings.btn1_label }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_url | default: '/collections' }}" class="btn btn--secondary">
            {{ section.settings.btn2_label }}
          </a>
        {%- endif -%}
      </div>

      <!-- Trust bar (blocks tipo trust_item) -->
      {%- assign trust_blocks = section.blocks | where: 'type', 'trust_item' -%}
      {%- if trust_blocks.size > 0 -%}
        <div class="line-hero__trust" aria-label="{{ 'sections.hero.trust_label' | t }}">
          {%- for block in trust_blocks -%}
            <div class="line-hero__trust-item" {{ block.shopify_attributes }}>
              <span class="line-hero__trust-icon-wrap">
                {%- case block.settings.icon -%}
                  {%- when 'truck' -%}
                    <svg class="line-hero__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <rect x="1" y="3" width="15" height="13" rx="1"/>
                      <path d="M16 8h4l3 3v5h-7V8z"/>
                      <circle cx="5.5" cy="18.5" r="2.5"/>
                      <circle cx="18.5" cy="18.5" r="2.5"/>
                    </svg>
                  {%- when 'lock' -%}
                    <svg class="line-hero__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <rect x="3" y="11" width="18" height="11" rx="2"/>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                  {%- when 'shield' -%}
                    <svg class="line-hero__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                      <path d="m9 12 2 2 4-4"/>
                    </svg>
                  {%- else -%}
                    <svg class="line-hero__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path d="M20 6 9 17l-5-5"/>
                    </svg>
                {%- endcase -%}
              </span>
              <span class="line-hero__trust-text">
                <span class="line-hero__trust-title">{{ block.settings.text }}</span>
                {%- if block.settings.subtitle != blank -%}
                  <span class="line-hero__trust-subtitle">{{ block.settings.subtitle }}</span>
                {%- endif -%}
              </span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div><!-- /content -->

  </div><!-- /inner -->

</section>

<script>
(function () {
  var section = document.getElementById('line-hero-{{ section.id }}');
  if (!section || !window.LINE) return;
  window.LINE.registerAnim(
    section,
    function (el) {
      if (!window.gsap) return;
      var gsap = window.gsap;
      var contentEls = el.querySelector('.line-hero__content') ? el.querySelector('.line-hero__content').children : [];
      gsap.from(contentEls, { opacity: 0, y: 28, duration: 0.85, stagger: 0.11, ease: 'power3.out', clearProps: 'opacity,transform' });
    },
    ['gsap'],
    '0px'
  );
})();
</script>

{% schema %}
{
  "name": "Hero LINE",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "label",
      "default": "Bienestar para tu día a día",
      "label": "Etiqueta sobre el título"
    },
    {
      "type": "text",
      "id": "title_line_1",
      "default": "Descansa mejor.",
      "label": "Título — línea 1"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "default": "Muévete sin dolor.",
      "label": "Título — línea 2"
    },
    {
      "type": "text",
      "id": "title_line_3",
      "default": "Siéntete bien.",
      "label": "Título — línea 3 (degradado champán)"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "default": "Una selección de productos de bienestar pensados para verse bien, sentirse mejor y vivir con más comodidad.",
      "label": "Subtítulo"
    },
    {
      "type": "header",
      "content": "Botones"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "default": "Descubrir la colección",
      "label": "Botón 1 — texto"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Botón 1 — enlace"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "default": "Explorar productos",
      "label": "Botón 2 — texto"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Botón 2 — enlace"
    },
    {
      "type": "header",
      "content": "Video de fondo"
    },
    {
      "type": "checkbox",
