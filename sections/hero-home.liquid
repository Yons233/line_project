            { "value": "truck",  "label": "Camión (envío)" },
            { "value": "lock",   "label": "Candado (pago seguro)" },
            { "value": "shield", "label": "Escudo (garantía)" },
            { "value": "check",  "label": "Check genérico" }
          ]
        },
        {
          "type": "text",
          "id": "text",
          "default": "Envío a todo el país",
          "label": "Texto"
        },
        {
          "type": "text",
          "id": "subtitle",
          "default": "Recíbelo donde estés",
          "label": "Subtítulo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero LINE",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "truck",  "text": "Envío a todo el país",    "subtitle": "Recíbelo donde estés" } },
        { "type": "trust_item", "settings": { "icon": "lock",   "text": "Pago seguro",              "subtitle": "Tus datos protegidos" } },
        { "type": "trust_item", "settings": { "icon": "shield", "text": "Garantía de satisfacción", "subtitle": "Compra con confianza" } }
      ]
    }
  ]
}
