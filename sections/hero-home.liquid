      "default": true,
      "label": "Activar video de fondo (OficialHero.mp4, solo desktop)",
      "info": "En móvil y con 'reducir movimiento' activado queda solo el color base del hero."
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
