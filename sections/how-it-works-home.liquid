{% stylesheet %}
.line-how {
  padding-top: var(--space-16);
  padding-bottom: var(--space-10);
  background: var(--white);
}

.line-how__card {
  position: relative;
  max-width: 1400px;
  margin-inline: auto;
  padding: var(--space-16) var(--space-10);
  border-radius: 32px;
  background: radial-gradient(circle at 50% 0%, rgba(231,211,179,0.28) 0%, rgba(247,242,234,0.55) 45%, rgba(247,242,234,0.85) 100%);
  overflow: hidden;
}

/* ── Encabezado ── */
.line-how__header {
  text-align: center;
  max-width: 560px;
  margin-inline: auto;
}
.line-how__eyebrow {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--champagne-1);
}
.line-how__title {
  margin-top: var(--space-3);
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
  letter-spacing: -0.02em;
  line-height: 1.2;
  color: var(--ink);
}

/* ── Pasos ── */
.line-how__steps {
  --badge: 56px;
  --gap: 2rem;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: var(--gap);
  margin-top: var(--space-12);
}

.line-how__step {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-3);
}

/* Conector punteado entre insignias: elemento real (no ::after) para que GSAP
   pueda animarlo; visible por defecto, el "dibujado" es solo una mejora. */
.line-how__connector {
  position: absolute;
  top: calc(var(--badge) / 2 - 1px);
  left: calc(50% + var(--badge) / 2 + 10px);
  width: calc(100% - var(--badge) + var(--gap) - 20px);
  border-top: 2px dotted rgba(189,151,99,0.5);
  transform-origin: left center;
}

.line-how__badge-wrap {
  position: relative;
  width: var(--badge);
  height: var(--badge);
}
.line-how__badge-wrap::before {
  content: '';
  position: absolute;
  inset: -8px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(189,151,99,0.30), transparent 72%);
  opacity: 0.7;
  animation: line-how-pulse 4.5s ease-in-out infinite;
}
.line-how__step:nth-child(2) .line-how__badge-wrap::before { animation-delay: .6s; }
.line-how__step:nth-child(3) .line-how__badge-wrap::before { animation-delay: 1.2s; }
.line-how__step:nth-child(4) .line-how__badge-wrap::before { animation-delay: 1.8s; }
.line-how__step:nth-child(5) .line-how__badge-wrap::before { animation-delay: 2.4s; }
@keyframes line-how-pulse {
  0%, 100% { opacity: 0.45; transform: scale(1); }
  50%      { opacity: 0.85; transform: scale(1.12); }
}

.line-how__badge {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--champagne-2) 0%, var(--champagne-1) 100%);
  box-shadow: 0 10px 22px rgba(189,151,99,0.35);
  color: var(--white);
  font-family: var(--font-body);
  font-weight: 700;
  font-size: var(--text-lg);
  transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo);
}
.line-how__step:hover .line-how__badge {
  transform: scale(1.08);
  box-shadow: 0 14px 28px rgba(189,151,99,0.45);
}

.line-how__step-title {
  font-family: var(--font-body);
  font-weight: 700;
  font-size: var(--text-lg);
  color: var(--ink);
  transition: color 0.3s ease;
}
.line-how__step:hover .line-how__step-title { color: var(--champagne-1); }

.line-how__step-desc {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  line-height: 1.6;
  color: var(--ink-soft);
  max-width: 260px;
}

/* ── CTA ── */
.line-how__footer {
  margin-top: var(--space-10);
  text-align: center;
}

@media (prefers-reduced-motion: reduce) {
  .line-how__badge-wrap::before { animation: none; }
}

/* ── Responsive ── */
@media (max-width: 1100px) {
  .line-how__steps { grid-template-columns: repeat(3, 1fr); }
  .line-how__connector { display: none; }
}
@media (max-width: 900px) {
  .line-how__card { padding: var(--space-10) var(--space-6); border-radius: 24px; }
  .line-how__steps { grid-template-columns: 1fr; gap: var(--space-10); }
  .line-how__step-desc { max-width: 320px; }
}
{% endstylesheet %}

<section
  class="line-how"
  id="line-how-{{ section.id }}"
  aria-labelledby="how-title-{{ section.id }}"
>
  <div class="line-how__card">

    <div class="line-how__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="line-how__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="line-how__title" id="how-title-{{ section.id }}">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    {%- assign step_blocks = section.blocks | where: 'type', 'how_step' -%}
    {%- if step_blocks.size > 0 -%}
      <div class="line-how__steps">
        {%- for block in step_blocks -%}
          {%- assign step_number = forloop.index | prepend: '00' | slice: -2, 2 -%}
          <div class="line-how__step" {{ block.shopify_attributes }}>
            <div class="line-how__badge-wrap">
              <span class="line-how__badge">{{ step_number }}</span>
            </div>
            {%- unless forloop.last -%}
              <span class="line-how__connector" aria-hidden="true"></span>
            {%- endunless -%}
            {%- if block.settings.title != blank -%}
              <p class="line-how__step-title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="line-how__step-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <div class="line-how__footer">
        <a href="{{ section.settings.button_url | default: '/pages/como-funciona' }}" class="btn btn--secondary">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
(function () {
  var section = document.getElementById('line-how-{{ section.id }}');
  if (!section || !window.LINE) return;
  window.LINE.registerAnim(
    section,
    function (el) {
      if (!window.gsap) return;
      var gsap = window.gsap;
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return;

      var header = el.querySelector('.line-how__header');
      var footer = el.querySelector('.line-how__footer');
      var steps = el.querySelectorAll('.line-how__step');
      var connectors = el.querySelectorAll('.line-how__connector');

      var tweenBase = { opacity: 0, y: 22, duration: 0.7, ease: 'power3.out', clearProps: 'opacity,transform' };
      var tweenSteps = { opacity: 0, y: 26, duration: 0.6, stagger: 0.15, ease: 'power3.out', clearProps: 'opacity,transform' };
      var tweenConnectors = { scaleX: 0, transformOrigin: 'left center', duration: 0.8, stagger: 0.15, delay: 0.3, ease: 'power2.out', clearProps: 'transform' };

      if (window.ScrollTrigger) {
        gsap.registerPlugin(window.ScrollTrigger);
        var st = { trigger: el, start: 'top 78%', once: true };
        tweenBase.scrollTrigger = st;
        tweenSteps.scrollTrigger = st;
        tweenConnectors.scrollTrigger = st;
      }

      if (header) gsap.from(header, tweenBase);
      if (steps.length) gsap.from(steps, tweenSteps);
      if (connectors.length) gsap.from(connectors, tweenConnectors);
      if (footer) gsap.from(footer, Object.assign({}, tweenBase, { delay: 0.4 }));
    },
    ['gsap', 'ScrollTrigger'],
    '100px'
  );
})();
</script>

