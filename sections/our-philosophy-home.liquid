{% stylesheet %}
.line-philosophy {
  padding-top: var(--space-4);
  padding-bottom: var(--space-16);
  background: var(--white);
}

.line-philosophy__inner {
  max-width: 1560px;
  margin-inline: auto;
  padding-inline: var(--container-pad);
}

/* ── Encabezado ── */
.line-philosophy__header {
  text-align: center;
  max-width: 640px;
  margin-inline: auto;
}
.line-philosophy__eyebrow {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--champagne-1);
}
.line-philosophy__title {
  margin-top: var(--space-2);
  font-family: var(--font-serif);
  font-weight: 500;
  font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
  letter-spacing: -0.01em;
  color: var(--ink);
}
.line-philosophy__subtitle {
  margin-top: var(--space-3);
  font-family: var(--font-body);
  font-size: var(--text-base);
  color: var(--ink-soft);
}

/* ── Grid de tarjetas ── */
.line-philosophy__grid {
  margin-top: var(--space-10);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}

.line-philosophy__card {
  position: relative;
  aspect-ratio: 16 / 10;
  border-radius: var(--radius-lg);
  overflow: hidden;
  isolation: isolate;
}
.line-philosophy__card-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.line-philosophy__card-content {
  position: absolute;
  left: var(--space-6);
  top: var(--space-12);
  z-index: 2;
  width: min(56%, 260px);
}
.line-philosophy__card-title {
  font-family: var(--font-body);
  font-weight: 700;
  font-size: var(--text-lg);
  color: var(--white);
  text-shadow: 0 1px 3px rgba(0,0,0,0.35), 0 2px 12px rgba(0,0,0,0.25);
}
.line-philosophy__card-desc {
  margin-top: var(--space-2);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  line-height: 1.6;
  color: rgba(255,255,255,0.92);
  text-shadow: 0 1px 3px rgba(0,0,0,0.4), 0 2px 12px rgba(0,0,0,0.3);
  text-align: justify;
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .line-philosophy__grid { grid-template-columns: 1fr; }
  .line-philosophy__card-content { width: min(70%, 320px); }
}
{% endstylesheet %}

<section
  class="line-philosophy"
  id="line-philosophy-{{ section.id }}"
  aria-labelledby="philosophy-title-{{ section.id }}"
>
  <div class="line-philosophy__inner">

    <div class="line-philosophy__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="line-philosophy__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="line-philosophy__title" id="philosophy-title-{{ section.id }}">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="line-philosophy__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- assign item_blocks = section.blocks | where: 'type', 'philosophy_item' -%}
    {%- if item_blocks.size > 0 -%}
      <div class="line-philosophy__grid">
        {%- for block in item_blocks -%}
          <div class="line-philosophy__card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag:
                  class: 'line-philosophy__card-img',
                  loading: 'lazy',
                  alt: block.settings.title,
                  widths: '480,700,900'
              }}
            {%- else -%}
              <img
                src="{{ block.settings.fallback_filename | asset_url }}"
                alt="{{ block.settings.title }}"
                loading="lazy"
                width="1200"
                height="900"
                class="line-philosophy__card-img"
              >
            {%- endif -%}
            <div class="line-philosophy__card-content">
              {%- if block.settings.title != blank -%}
                <h3 class="line-philosophy__card-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="line-philosophy__card-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script>
(function () {
  var section = document.getElementById('line-philosophy-{{ section.id }}');
  if (!section || !window.LINE) return;
  window.LINE.registerAnim(
    section,
    function (el) {
      if (!window.gsap) return;
      var gsap = window.gsap;
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return;

      var headerEls = el.querySelector('.line-philosophy__header') ? el.querySelector('.line-philosophy__header').children : [];
      var cards = el.querySelectorAll('.line-philosophy__card');

      var tweenHeader = { opacity: 0, y: 22, duration: 0.7, stagger: 0.1, ease: 'power3.out', clearProps: 'opacity,transform' };
      var tweenCards = { opacity: 0, y: 26, duration: 0.6, stagger: 0.12, ease: 'power3.out', clearProps: 'opacity,transform' };

      if (window.ScrollTrigger) {
        gsap.registerPlugin(window.ScrollTrigger);
        tweenHeader.scrollTrigger = { trigger: el, start: 'top 78%', once: true };
        tweenCards.scrollTrigger = { trigger: el, start: 'top 78%', once: true };
      }

      if (headerEls.length) gsap.from(headerEls, tweenHeader);
      if (cards.length) gsap.from(cards, tweenCards);
    },
    ['gsap', 'ScrollTrigger'],
    '100px'
  );
})();
</script>

