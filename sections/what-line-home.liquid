{% stylesheet %}
.line-why {
  padding-top: var(--space-10);
  padding-bottom: var(--space-8);
  background: var(--white);
  overflow: hidden;
}

.line-why__inner {
  display: grid;
  grid-template-columns: minmax(240px, 320px) minmax(280px, 520px) minmax(280px, 360px);
  gap: var(--space-12);
  align-items: center;
  justify-content: space-between;
  max-width: 1400px;
  margin-inline: auto;
  padding-inline: calc(var(--container-pad) - 24px);
}

/* ── Columna izquierda ── */
.line-why__intro {
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.line-why__eyebrow {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--champagne-1);
}
.line-why__title {
  margin-top: var(--space-3);
  font-family: var(--font-serif);
  font-weight: 500;
  font-size: clamp(var(--text-2xl), 3.2vw, var(--text-4xl));
  line-height: 1.15;
  letter-spacing: -0.01em;
  color: var(--ink);
}
.line-why__title-highlight {
  background: var(--gradient-champagne);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.line-why__body {
  margin-top: var(--space-5);
  display: grid;
  gap: var(--space-4);
  max-width: 340px;
}
.line-why__body p {
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: 1.7;
  color: var(--ink-soft);
  text-align: justify;
}
.line-why__link {
  margin-top: var(--space-6);
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-body);
  font-weight: 600;
  font-size: var(--text-sm);
  color: var(--ink);
}
.line-why__link svg {
  width: 16px;
  height: 16px;
  transition: transform 0.3s var(--ease-out-expo);
}
.line-why__link:hover svg { transform: translateX(4px); }
.line-why__link-text {
  position: relative;
}
.line-why__link-text::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: -3px;
  height: 1px;
  background: currentColor;
  transform: scaleX(0.3);
  transform-origin: left;
  opacity: 0.35;
  transition: transform 0.35s var(--ease-out-expo), opacity 0.35s ease;
}
.line-why__link:hover .line-why__link-text::after {
  transform: scaleX(1);
  opacity: 0.9;
}

/* ── Columna central: imagen única ── */
.line-why__media {
  position: relative;
  width: 100%;
  max-width: 520px;
  aspect-ratio: 16 / 10;
  margin-inline: auto;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.line-why__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ── Columna derecha: lista vertical de razones ── */
.line-why__list {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-6);
}
.line-why__row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
}
.line-why__row-icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: radial-gradient(circle at 32% 26%, #ffffff 0%, rgba(255,255,255,0.9) 45%, rgba(231,211,179,0.4) 85%);
  border: 1px solid rgba(255,255,255,0.85);
  box-shadow: 0 3px 8px rgba(42,36,30,0.10), inset -1px -2px 3px rgba(189,151,99,0.16);
  color: var(--champagne-1);
}
.line-why__row-icon svg { width: 20px; height: 20px; }
.line-why__row-title {
  font-family: var(--font-body);
  font-weight: 700;
  font-size: var(--text-base);
  color: var(--ink);
}
.line-why__row-desc {
  margin-top: var(--space-1);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  line-height: 1.6;
  color: var(--ink-soft);
  text-align: justify;
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .line-why__inner { grid-template-columns: 1fr; gap: var(--space-10); }
  .line-why__eyebrow, .line-why__title { text-align: center; }
  .line-why__body { margin-inline: auto; text-align: center; }
  .line-why__link { margin-inline: auto; }
  .line-why__list { max-width: 480px; margin-inline: auto; }
}
@media (max-width: 700px) {
  .line-why__row { text-align: left; }
}
{% endstylesheet %}

<section
  class="line-why"
  id="line-why-{{ section.id }}"
  aria-labelledby="why-title-{{ section.id }}"
>
  <div class="line-why__inner">

    <div class="line-why__intro">
      {%- if section.settings.eyebrow != blank -%}
        <p class="line-why__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="line-why__title" id="why-title-{{ section.id }}">
        {{ section.settings.title_prefix }}
        {%- if section.settings.title_highlight != blank -%}
          <span class="line-why__title-highlight">{{ section.settings.title_highlight }}</span>
        {%- endif -%}
      </h2>

      {%- if section.settings.body_1 != blank or section.settings.body_2 != blank -%}
        <div class="line-why__body">
          {%- if section.settings.body_1 != blank -%}<p>{{ section.settings.body_1 }}</p>{%- endif -%}
          {%- if section.settings.body_2 != blank -%}<p>{{ section.settings.body_2 }}</p>{%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.link_label != blank -%}
        <a href="{{ section.settings.link_url | default: '/pages/acerca-de' }}" class="line-why__link">
          <span class="line-why__link-text">{{ section.settings.link_label }}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <div class="line-why__media">
      {%- if section.settings.center_image != blank -%}
        {{
          section.settings.center_image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            alt: section.settings.title_prefix,
            widths: '480,700,900'
        }}
      {%- else -%}
        <img
          src="{{ section.settings.center_image_fallback | default: 'PorqueLine.png' | asset_url }}"
          alt="{{ section.settings.title_prefix }}"
          loading="lazy"
          width="900"
          height="1000"
        >
      {%- endif -%}
    </div>

    {%- assign card_blocks = section.blocks | where: 'type', 'why_card' -%}
    {%- if card_blocks.size > 0 -%}
      <div class="line-why__list">
        {%- for block in card_blocks -%}
          <div class="line-why__row" {{ block.shopify_attributes }}>
            <span class="line-why__row-icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'star' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 2.5l2.9 5.88 6.5.94-4.7 4.58 1.11 6.47L12 17.27l-5.81 3.1 1.11-6.47-4.7-4.58 6.5-.94L12 2.5z"/>
                  </svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <path d="m9 12 2 2 4-4"/>
                  </svg>
                {%- when 'refresh' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                    <path d="M21 3v5h-5"/>
                    <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                    <path d="M3 21v-5h5"/>
                  </svg>
                {%- when 'heart' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="9"/>
                  </svg>
              {%- endcase -%}
            </span>
            <div>
              {%- if block.settings.title != blank -%}
                <h3 class="line-why__row-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="line-why__row-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script>
(function () {
  var section = document.getElementById('line-why-{{ section.id }}');
  if (!section || !window.LINE) return;
  window.LINE.registerAnim(
    section,
    function (el) {
      if (!window.gsap) return;
      var gsap = window.gsap;
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return;

      var introEls = el.querySelector('.line-why__intro') ? el.querySelector('.line-why__intro').children : [];
      var rows = el.querySelectorAll('.line-why__row');

      var tweenIntro = { opacity: 0, y: 22, duration: 0.7, stagger: 0.1, ease: 'power3.out', clearProps: 'opacity,transform' };
      var tweenRows = { opacity: 0, y: 18, duration: 0.6, stagger: 0.1, ease: 'power3.out', clearProps: 'opacity,transform' };

      if (window.ScrollTrigger) {
        gsap.registerPlugin(window.ScrollTrigger);
        tweenIntro.scrollTrigger = { trigger: el, start: 'top 78%', once: true };
        tweenRows.scrollTrigger = { trigger: el, start: 'top 78%', once: true };
      }

      if (introEls.length) gsap.from(introEls, tweenIntro);
      if (rows.length) gsap.from(rows, tweenRows);
    },
    ['gsap', 'ScrollTrigger'],
    '100px'
  );
})();
</script>

{% schema %}
{
  "name": "Por qué LINE",
  "tag": "section",
  "class": "section-what-line-home",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "¿Por qué LINE?",
      "label": "Etiqueta"
    },
    {
      "type": "text",
      "id": "title_prefix",
      "default": "Bienestar que nace de la",
      "label": "Título — texto"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "default": "confianza.",
      "label": "Título — palabra destacada (color pastel)"
    },
    {
      "type": "textarea",
      "id": "body_1",
      "default": "En LINE creemos que pequeños cambios pueden transformar tu día a día.",
      "label": "Párrafo 1"
    },
    {
      "type": "textarea",
      "id": "body_2",
      "default": "Por eso seleccionamos cuidadosamente productos innovadores que realmente marcan la diferencia en tu descanso, recuperación y bienestar general.",
      "label": "Párrafo 2"
    },
    {
      "type": "text",
      "id": "link_label",
      "default": "Conocer más sobre nosotros",
      "label": "Enlace — texto"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Enlace — URL (deja vacío para ir a Acerca de Nosotros)"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Imagen central"
    },
    {
      "type": "text",
      "id": "center_image_fallback",
      "default": "PorqueLine.png",
      "label": "Imagen central de respaldo (archivo en assets/)"
    }
  ],
  "blocks": [
    {
      "type": "why_card",
      "name": "Razón",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícono",
          "options": [
            { "value": "star", "label": "Estrella" },
            { "value": "shield", "label": "Escudo" },
            { "value": "refresh", "label": "Actualizar / Devolución" },
            { "value": "heart", "label": "Corazón" }
          ],
          "default": "star"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Selección experta",
          "label": "Título"
        },
        {
          "type": "textarea",
          "id": "description",
          "default": "Elegimos cada producto por su calidad, innovación y resultados comprobados.",
          "label": "Descripción"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Por qué LINE",
      "blocks": [
        {
          "type": "why_card",
          "settings": {
            "icon": "star",
            "title": "Selección experta",
            "description": "Elegimos cada producto por su calidad, innovación y resultados comprobados."
          }
        },
        {
          "type": "why_card",
          "settings": {
            "icon": "shield",
            "title": "Confianza garantizada",
            "description": "Compra segura, datos protegidos y pagos con los más altos estándares."
          }
        },
        {
          "type": "why_card",
          "settings": {
            "icon": "refresh",
            "title": "Devoluciones fáciles",
            "description": "14 días para cambiar de opinión, sin formularios interminables, sin complicaciones."
          }
        }
      ]
    }
  ]
}
{% endschema %}
