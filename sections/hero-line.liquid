{% stylesheet %}
/* ── Hero container ── */
.line-hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  padding-top: calc(var(--header-h) + var(--space-16));
  padding-bottom: var(--space-16);
  background-color: var(--cream-0);
}

/* ── Fondo ── */
.line-hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.line-hero__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 66% center;
}
.line-hero__bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(247,242,234,0.32) 0%,
    rgba(239,231,218,0.16) 45%,
    rgba(247,242,234,0.04) 100%
  );
}

/* ── Partículas ── */
.line-hero__particles-wrap {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

/* ── Inner grid (texto izquierda / productos derecha) ── */
.line-hero__inner {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-12);
  align-items: center;
  max-width: 1560px;
  margin-inline: auto;
  padding-inline: var(--container-pad);
  width: 100%;
}

/* ── Columna de texto ── */
.line-hero__content {
  display: grid;
  gap: var(--space-6);
  margin-top: -5.5rem;
}

.line-hero__label {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  background: rgba(255,255,255,0.55);
  border: 1px solid rgba(189,151,99,0.28);
  font-size: var(--text-sm);
  font-weight: 500;
  letter-spacing: normal;
  text-transform: none;
  color: var(--ink);
  width: fit-content;
}
.line-hero__label-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--champagne-1);
  flex-shrink: 0;
}

.line-hero__title {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: clamp(2.5rem, 5.5vw, 5.5rem);
  line-height: 1.0;
  letter-spacing: -0.03em;
  color: var(--ink);
}
.line-hero__title-line { display: block; }
.line-hero__title-line--gradient {
  background: var(--gradient-champagne);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.line-hero__subtitle {
  font-size: clamp(var(--text-base), 1.4vw, var(--text-lg));
  color: var(--ink-soft);
  line-height: 1.7;
  max-width: 480px;
}

.line-hero__cta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  align-items: center;
}

/* ── Trust bar ── */
.line-hero__trust {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-6);
  align-items: center;
  padding-top: var(--space-4);
}
.line-hero__trust-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}
.line-hero__trust-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  background: rgba(255,255,255,0.55);
  border: 1px solid rgba(42,36,30,0.10);
  flex-shrink: 0;
}
.line-hero__trust-icon {
  width: 18px;
  height: 18px;
  color: var(--ink);
  flex-shrink: 0;
}
.line-hero__trust-text {
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.line-hero__trust-title {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--ink);
  line-height: 1.3;
}
.line-hero__trust-subtitle {
  font-size: var(--text-xs);
  color: var(--ink-soft);
  line-height: 1.3;
}

/* ── Columna de producto (derecha): tarjetas de vidrio flotantes ── */
.line-hero__products {
  position: relative;
  min-height: 380px;
  width: 100%;
}

/* Animación flotante */
@keyframes line-float {
  0%, 100% { transform: translateY(0px); }
  50%       { transform: translateY(-10px); }
}

.line-hero__product-card {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  width: 148px;
  padding: var(--space-6) var(--space-4);
  text-align: center;
  background: rgba(247,242,234,0.5);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.55);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  animation: line-float 3.6s ease-in-out infinite;
  animation-delay: var(--card-delay, 0s);
}
.line-hero__product-card:nth-of-type(1) { top: 10%;  left: 2%; }
.line-hero__product-card:nth-of-type(2) {
  top: 0;
  left: 32%;
  width: 174px;
  padding: var(--space-8) var(--space-5);
  z-index: 1;
}
.line-hero__product-card:nth-of-type(3) { top: 16%; left: 68%; }

.line-hero__product-emoji {
  font-size: 2rem;
  line-height: 1;
  flex-shrink: 0;
}
.line-hero__product-brand {
  font-family: var(--font-heading);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--champagne-1);
}
.line-hero__product-name {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: var(--text-sm);
  color: var(--ink);
  line-height: 1.25;
}

/* Burbujas de vidrio decorativas */
.line-hero__bubble {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle at 32% 28%, rgba(255,255,255,0.95), rgba(255,255,255,0.18) 60%, rgba(255,255,255,0.05) 100%);
  box-shadow: 0 8px 20px rgba(42,36,30,0.08), inset 0 0 14px rgba(255,255,255,0.5);
  animation: line-float 4.6s ease-in-out infinite;
}
.line-hero__bubble--1 { width: 58px; height: 58px; top: 2%;  left: 26%; animation-delay: .2s; }
.line-hero__bubble--2 { width: 26px; height: 26px; top: 46%; left: 58%; animation-delay: 1.1s; }
.line-hero__bubble--3 { width: 20px; height: 20px; top: 34%; left: 92%; animation-delay: .6s; }
.line-hero__bubble--4 { width: 14px; height: 14px; top: 62%; left: 12%; animation-delay: 1.6s; }

@media (prefers-reduced-motion: reduce) {
  .line-hero__product-card,
  .line-hero__bubble { animation: none; }
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .line-hero__inner { grid-template-columns: 1fr; }
  .line-hero__products { display: none; }
}
@media (max-width: 600px) {
  .line-hero__title { letter-spacing: -0.02em; }
  .line-hero__trust { gap: var(--space-4); }
}
{% endstylesheet %}

<section
  class="line-hero"
  id="line-hero-{{ section.id }}"
  aria-labelledby="hero-title-{{ section.id }}"
>

  <!-- Imagen de fondo -->
  <div class="line-hero__bg" aria-hidden="true">
    {%- if section.settings.bg_image != blank -%}
      {{
        section.settings.bg_image
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          alt: '',
          widths: '768,1024,1440,1920',
          sizes: '100vw'
      }}
    {%- else -%}
      <img
        src="{{ 'HeroFondo.png' | asset_url }}"
        alt=""
        loading="eager"
        fetchpriority="high"
        width="2400"
        height="1162"
      >
    {%- endif -%}
    <div class="line-hero__bg-overlay"></div>
  </div>

  <!-- Partículas 3D (lazy, solo desktop) -->
  {%- if section.settings.show_particles -%}
    <div class="line-hero__particles-wrap">
      {%- render 'particles-3d',
          particle_count: section.settings.particle_count,
          particle_color: section.settings.particle_color,
          particle_size: section.settings.particle_size,
          section_id: section.id
      -%}
    </div>
  {%- endif -%}

  <!-- Grid principal -->
  <div class="line-hero__inner">

    <!-- Columna izquierda: texto -->
    <div class="line-hero__content">

      {%- if section.settings.label != blank -%}
        <p class="line-hero__label">
          <span class="line-hero__label-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M12 5v14M5 12h14"/>
            </svg>
          </span>
          {{ section.settings.label }}
        </p>
      {%- endif -%}

      <h1 class="line-hero__title" id="hero-title-{{ section.id }}">
        {%- if section.settings.title_line_1 != blank -%}
          <span class="line-hero__title-line">{{ section.settings.title_line_1 }}</span>
        {%- endif -%}
        {%- if section.settings.title_line_2 != blank -%}
          <span class="line-hero__title-line">{{ section.settings.title_line_2 }}</span>
        {%- endif -%}
        {%- if section.settings.title_line_3 != blank -%}
          <span class="line-hero__title-line line-hero__title-line--gradient">{{ section.settings.title_line_3 }}</span>
        {%- endif -%}
      </h1>

      {%- if section.settings.subtitle != blank -%}
        <p class="line-hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <div class="line-hero__cta">
        {%- if section.settings.btn1_label != blank -%}
          <a href="{{ section.settings.btn1_url | default: '/collections/all' }}" class="btn btn--primary">
            {{ section.settings.btn1_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_url | default: '/collections' }}" class="btn btn--secondary">
            {{ section.settings.btn2_label }}
          </a>
        {%- endif -%}
      </div>

      <!-- Trust bar (blocks tipo trust_item) -->
      {%- assign trust_blocks = section.blocks | where: 'type', 'trust_item' -%}
      {%- if trust_blocks.size > 0 -%}
        <div class="line-hero__trust" aria-label="{{ 'sections.hero.trust_label' | t }}">
          {%- for block in trust_blocks -%}
            <div class="line-hero__trust-item" {{ block.shopify_attributes }}>
              <span class="line-hero__trust-icon-wrap">
                {%- case block.settings.icon -%}
                  {%- when 'truck' -%}
                    <svg class="line-hero__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <rect x="1" y="3" width="15" height="13" rx="1"/>
                      <path d="M16 8h4l3 3v5h-7V8z"/>
                      <circle cx="5.5" cy="18.5" r="2.5"/>
                      <circle cx="18.5" cy="18.5" r="2.5"/>
                    </svg>
                  {%- when 'lock' -%}
                    <svg class="line-hero__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <rect x="3" y="11" width="18" height="11" rx="2"/>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                  {%- when 'shield' -%}
                    <svg class="line-hero__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                      <path d="m9 12 2 2 4-4"/>
                    </svg>
                  {%- else -%}
                    <svg class="line-hero__trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path d="M20 6 9 17l-5-5"/>
                    </svg>
                {%- endcase -%}
              </span>
              <span class="line-hero__trust-text">
                <span class="line-hero__trust-title">{{ block.settings.text }}</span>
                {%- if block.settings.subtitle != blank -%}
                  <span class="line-hero__trust-subtitle">{{ block.settings.subtitle }}</span>
                {%- endif -%}
              </span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div><!-- /content -->

    <!-- Columna derecha: slots de producto flotantes -->
    {%- assign product_blocks = section.blocks | where: 'type', 'product_card' -%}
    {%- if product_blocks.size > 0 -%}
      <div class="line-hero__products" aria-hidden="true">
        <span class="line-hero__bubble line-hero__bubble--1"></span>
        <span class="line-hero__bubble line-hero__bubble--2"></span>
        <span class="line-hero__bubble line-hero__bubble--3"></span>
        <span class="line-hero__bubble line-hero__bubble--4"></span>
        {%- for block in product_blocks -%}
          {%- assign delay_s = forloop.index0 | times: 0.9 -%}
          <div
            class="line-hero__product-card"
            style="--card-delay: {{ delay_s }}s;"
            {{ block.shopify_attributes }}
          >
            <span class="line-hero__product-emoji">{{ block.settings.emoji | default: '✨' }}</span>
            <span class="line-hero__product-brand">LINE</span>
            <span class="line-hero__product-name">{{ block.settings.name }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div><!-- /inner -->

</section>

<script>
(function () {
  var section = document.getElementById('line-hero-{{ section.id }}');
  if (!section || !window.LINE) return;
  window.LINE.registerAnim(
    section,
    function (el) {
      if (!window.gsap) return;
      var children = el.querySelector('.line-hero__content') ? el.querySelector('.line-hero__content').children : [];
      window.gsap.from(children, { opacity: 0, y: 28, duration: 0.85, stagger: 0.11, ease: 'power3.out', clearProps: 'all' });
    },
    ['gsap'],
    '0px'
  );
})();
</script>

