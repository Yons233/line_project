<!doctype html>
<html
  lang="{{ request.locale.iso_code }}"
  dir="{{ settings.text_direction | default: 'ltr' }}"
>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#f7f2ea">

  {%- if page_title == blank -%}
    <title>{{ shop.name }}</title>
  {%- else -%}
    <title>{{ page_title }}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
  {%- endif -%}

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <!-- Canonical & hreflang -->
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | default: shop.name | escape }}">
  <meta property="og:type" content="website">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  {%- if page_image -%}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
    <meta property="og:image:width" content="1200">
  {%- endif -%}

  <!-- Structured data: Organization -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }},
    "logo": {{ shop.brand.logo | image_url: width: 400 | prepend: 'https:' | json }},
    "sameAs": [
      {{ settings.social_instagram_link | json }},
      {{ settings.social_facebook_link | json }}
    ]
  }
  </script>

  <!-- Favicon -->
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <!-- Google Fonts: preconnect primero, después el href real -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,800&family=Hanken+Grotesk:wght@400;500;600&display=swap"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,800&family=Hanken+Grotesk:wght@400;500;600&display=swap"
    >
  </noscript>

  <!-- Tokens de diseño LINE (inline para evitar FOUC) -->
  {%- render 'css-variables' -%}

  <!-- CSS del tema -->
  {{ 'line-theme.css' | asset_url | stylesheet_tag }}

  <!-- Preload del cargador de animaciones (no bloquea render) -->
  <link rel="modulepreload" href="{{ 'line-anim.js' | asset_url }}" as="script">

  {{ content_for_header }}
</head>

<body class="{% if template == 'index' %}template-index{% endif %}">

  {%- section 'header' -%}

  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <!-- line-anim.js: cargador lazy de animaciones (defer, no bloquea) -->
  <script src="{{ 'line-anim.js' | asset_url }}" defer></script>

  <!-- Accesibilidad: skip-to-content -->
  <a href="#main-content" class="skip-to-content visually-hidden">
    {{ 'accessibility.skip_to_content' | t }}
  </a>

</body>
</html>
